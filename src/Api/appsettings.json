{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Database=finflow_db;Username=postgres;Password=postgres123",
    "Redis": "localhost:6379"
  },
  "ForwardedHeaders": {
    "KnownProxies": [ "YOUR_PROXY_IP_HERE" ] 
  },
  "JwtSettings": {
    "Secret": "YOUR_SUPER_SECRET_KEY_HERE_MUST_BE_32_CHARS",
    "Issuer": "FinFlow",
    "Audience": "FinFlow",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "AuthChallenge": {
    "VerificationTokenLifetimeMinutes": 15,
    "VerificationCooldownSeconds": 90,
    "OtpLength": 6,
    "TokenByteLength": 32,
    "TokenHashKey": "YOUR_EMAIL_CHALLENGE_SECRET_KEY",
    "VerificationLinkBaseUrl": "https://YOUR_APP_HOST/email/verify"
  },
"EmailDelivery": {
    "SenderAddress": "no-reply@finflow.example",
    "SenderName": "FinFlow",
    "VerificationSubject": "Verify your email",
    "PasswordResetSubject": "Reset your password"
  },
"Ocr": {
    "ActiveProvider": "Groq",
    "Groq": {
      "BaseUrl": "https://api.groq.com/openai/v1",
      "ApiKey": "",
      "Model": "meta-llama/llama-4-scout-17b-16e-instruct",
      "MaxPagesPerDocument": 3,
      "MaxImagesPerRequest": 5,
      "MaxImageBytes": 4194304,
      "RequestTimeoutSeconds": 60
    },
    "OpenRouter": {
      "BaseUrl": "https://openrouter.ai/api/v1/",
      "ApiKey": "",
      "Model": "google/gemini-2.0-flash-exp:free",
      "MaxPagesPerDocument": 3,
      "MaxImagesPerRequest": 5,
      "MaxImageBytes": 4194304,
      "RequestTimeoutSeconds": 60,
      "Referer": "https://finflow.local",
      "Title": "FinFlow OCR"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*"
}
