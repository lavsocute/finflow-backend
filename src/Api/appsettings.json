{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=finflow_db;Username=postgres;Password=YOUR_DB_PASSWORD",
    "Redis": "localhost:6379"
  },
  "ForwardedHeaders": {
    "KnownProxies": [ "YOUR_PROXY_IP_HERE" ] 
  },
  "JwtSettings": {
    "Secret": "YOUR_SUPER_SECRET_KEY_HERE_MUST_BE_32_CHARS",
    "Issuer": "FinFlow",
    "Audience": "FinFlow",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
